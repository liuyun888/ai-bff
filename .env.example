# ai-bff 环境变量示例（复制为 .env 后按需改）
# 下游 AI 引擎（须对齐 ai-service 的 APP_PORT；本机常用 8091）
AI_SERVICE_BASE_URL=http://127.0.0.1:8091
# BFF 自己的监听端口（勿与 ai-service 撞车）
BFF_PORT=8088
# 10.02：下游 HTTP 超时（秒）与 health 重试次数
AI_CONNECT_TIMEOUT=2.0
AI_READ_TIMEOUT=3.0
AI_HEALTH_MAX_RETRIES=2
# 10.03：SSE 流式读空闲超时（秒）；总对话可很长，但多久没新字节要封顶
AI_STREAM_READ_TIMEOUT=120.0
# 10.04：与 ai-service 共享的内部密钥（只放服务端）
INTERNAL_TOKEN=dev-internal-token
# 演示 Bearer：token:user_id:tenant_id，逗号分隔
DEMO_BEARER_USERS=tok-alice:u-alice:tenant-a,tok-bob:u-bob:tenant-b
